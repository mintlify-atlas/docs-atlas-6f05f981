    "DataManager::add_alpha_vantage_provider(api_key)",
    "Strategy::initialize(config)",
    "Strategy::on_market_event(event, context)",
    "Strategy::on_order_event(event, context)",
    "BuyAndHoldStrategy::new()",
    "MovingAverageCrossoverStrategy::new(short_period, long_period)",
    "MomentumStrategy::new(lookback, threshold)",
    "MeanReversionStrategy::new(lookback, entry_threshold, exit_threshold)",
    "RsiStrategy::new(period, oversold, overbought)",
    "Portfolio::new(account_id, initial_capital)",
    "Portfolio::get_position(symbol)",
    "StrategyContext::get_current_price(symbol)",
    "StrategyContext::get_available_cash()",
