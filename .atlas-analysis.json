  "keyFeatures": [
    "Event-driven backtesting engine with realistic market simulation",
    "Multi-asset support (equities and crypto) with asset-class-aware fees",
    "Rust core for high performance with Python bindings for ease of use",
    "Built-in strategy library (Buy & Hold, MA Crossover, Momentum, Mean Reversion, RSI)",
    "Arrow/Parquet columnar storage with SQLite metadata catalog",
    "Streamlit UI for interactive strategy development and analysis",
    "FastAPI gateway for programmatic access",
    "Performance analytics (Sharpe, Sortino, Calmar, Max Drawdown, etc.)",
    "Risk analytics (VaR, CVaR, skewness, kurtosis)",
    "Configurable slippage, latency, and commission models"
  ],
  "publicApiSurface": [
    "BacktestEngine::new(config)",
    "BacktestEngine::run()",
    "BacktestEngine::run_with_strategy(strategy)",
